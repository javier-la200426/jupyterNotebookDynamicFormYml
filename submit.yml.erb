---
batch_connect:
  template: "basic"

script:
  native:
    - "--time=<%= bc_num_hours %>:00:00"
    - "--cpus-per-task=<%= num_cores %>"
    - "--mem=<%= num_memory %>G"
    - "--nodes=1"
    - "-p <%= partition %>"
<%
  skip_gres = gpu_type == "none" || ["batch", "largemem", "rc2", "pangolinlab", "ruiguolab", "shushkovlab", "vaseylab"].include?(partition)
%>
<% unless skip_gres %>
  <% if gpu_type == "any" %>
    - "--gres=gpu:1"
  <% elsif gpu_type.include?("-") %>
    <%# Feature-variant id like 'a100-80G': base is the SLURM gres name, full id is a constraint %>
    - "--gres=gpu:<%= gpu_type.split('-', 2).first %>:1"
    - "--constraint=<%= gpu_type %>"
  <% else %>
    - "--gres=gpu:<%= gpu_type %>:1"
  <% end %>
<% end %>